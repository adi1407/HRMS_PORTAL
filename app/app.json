{
  "expo": {
    "name": "HRMS",
    "slug": "hrms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hrms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aditya.hrms",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "HRMS uses Face ID to confirm attendance enrollment and check-in on this device."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.aditya.hrms",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "HRMS uses Face ID to confirm attendance enrollment and check-in on this device."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HRMS to use the camera for attendance and face enrollment."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#6366f1",
          "dark": {
            "backgroundColor": "#6366f1"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "404c003a-5543-43b7-ac90-ced54e17556f"
      }
    }
  }
}
