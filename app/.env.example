# Copy to .env and adjust. Expo loads EXPO_PUBLIC_* at build/start time.

# ── Recommended when you move between places (home / office / travel) ──
# Use your deployed API (Render, Railway, VPS, etc.) — no laptop IP needed.
# EXPO_PUBLIC_API_URL=https://your-hrms-api.onrender.com

# ── Local backend on this machine (phone must be on same Wi‑Fi) ──
# Your laptop IP changes when you change location — run: npm run dev:ip
# Then set (replace with the printed IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.50:5000

# ── Localhost only works for web / Android emulator on same PC ──
# EXPO_PUBLIC_API_URL=http://localhost:5000
